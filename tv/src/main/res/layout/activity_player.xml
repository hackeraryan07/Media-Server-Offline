<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.media3.ui.PlayerView
        android:id="@+id/video_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center" />

    <!-- Header Overlay -->
    <LinearLayout
        android:id="@+id/player_meta_overlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#99000000"
        android:padding="24dp"
        android:layout_gravity="top"
        android:elevation="10dp">
        
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/player_video_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Video Title"
                android:textColor="#F3F4F6"
                android:textStyle="bold"
                android:textSize="22sp"/>

            <TextView
                android:id="@+id/player_video_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Streaming from Mobile Wi-Fi Server"
                android:textColor="#9CA3AF"
                android:textSize="14sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>
        
        <Button
            android:id="@+id/btn_add_queue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add to Up Next"
            android:layout_gravity="center_vertical"
            android:backgroundTint="#6750A4"
            android:textColor="#FFFFFF"
            android:visibility="gone" />
    </LinearLayout>

</FrameLayout>
